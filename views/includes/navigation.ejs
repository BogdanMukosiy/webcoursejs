<header class="main-header">
    <nav class="main-header__nav">
        <ul class="main-header__item-list">
            <li class="main-header__item"><a class="<%= path === '/' ? 'active' : '' %>" href="/">Магазин</a></li>
            <li class="main-header__item"><a class="<%= path === '/products' ? 'active' : '' %>" href="/products">Товари</a></li>

            <% if (isAuthenticated) { %>
                <li class="main-header__item"><a class="<%= path === '/cart' ? 'active' : '' %>" href="/cart">Кошик</a></li>
                <li class="main-header__item"><a class="<%= path === '/orders' ? 'active' : '' %>" href="/orders">Замовлення</a></li>
                <li class="main-header__item"><a class="<%= path === '/admin/add-product' ? 'active' : '' %>" href="/admin/add-product">Додати товар</a></li>
                <li class="main-header__item"><a class="<%= path === '/admin/products' ? 'active' : '' %>" href="/admin/products">Адмін-товари</a></li>
            <% } %>
        </ul>
        <ul class="main-header__item-list">
            <% if (!isAuthenticated) { %>
                <li class="main-header__item"><a class="<%= path === '/login' ? 'active' : '' %>" href="/login">Увійти</a></li>
            <% } else { %>
                <li class="main-header__item">
                    <form action="/logout" method="POST">
                        <button type="submit">Вийти</button>
                    </form>
                </li>
            <% } %>
        </ul>
    </nav>
</header>