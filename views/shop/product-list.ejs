<%- include('../includes/head.ejs') %>
</head>
<body>
<%- include('../includes/navigation.ejs') %>
<main>
    <h1>Всі товари</h1>
    <% if (prods.length > 0) { %>
        <div class="grid">
            <% prods.forEach(product => { %>
                <article class="card product-item">
                    <header class="card__header"><h1 class="product__title"><%= product.title %></h1></header>
                    <div class="card__image"><img src="<%= product.imageUrl %>" alt="<%= product.title %>" style="width:200px;"></div>
                    <div class="card__content">
                        <h2 class="product__price">$<%= product.price %></h2>
                        <p class="product__description"><%= product.description %></p>
                    </div>
                    <div class="card__actions">
                        <% if (isAuthenticated) { %>
                            <form action="/cart" method="POST">
                                <button class="btn" type="submit">Додати в кошик</button>
                                <input type="hidden" name="productId" value="<%= product._id %>">
                            </form>
                        <% } %>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } else { %>
        <h1>Товарів не знайдено!</h1>
    <% } %>
</main>
<%- include('../includes/end.ejs') %>